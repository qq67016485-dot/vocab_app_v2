SECRET_KEY='your-secret-key-here'

DEBUG=True

DATABASE_URL='mysql://root:password@127.0.0.1:3306/vocabulary_v2_db'

ALLOWED_HOSTS=127.0.0.1,localhost

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
GEMINI_API_KEY=
# Optional OpenAI-compatible proxy URL for Gemini (e.g., https://api.b.ai/v1).
# When set, call_gemini routes through the OpenAI SDK against {base_url}/chat/completions.
# Leave empty to call Google's native API via the google.genai SDK.
GEMINI_BASE_URL=

# Read-along audiobook TTS (Gemini native TTS). Separate from the text Gemini
# config above because audio needs the native generateContent API, which an
# OpenAI-compatible text proxy usually does not serve.
# - GEMINI_TTS_API_KEY: key for the TTS endpoint (falls back to GEMINI_API_KEY if empty).
# - GEMINI_TTS_BASE_URL: optional proxy that serves the NATIVE Gemini TTS API.
#   Leave empty to call Google directly.
# - GEMINI_TTS_MODEL: defaults to gemini-2.5-pro-preview-tts.
GEMINI_TTS_API_KEY=
GEMINI_TTS_BASE_URL=
GEMINI_TTS_MODEL=gemini-2.5-pro-preview-tts

# Image generation (OpenAI GPT-Image-2)
OPENAI_API_KEY=
OPENAI_BASE_URL=

QWEN_API_KEY=
QWEN_BASE_URL=https://api.siliconflow.cn/v1/embeddings
QWEN_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
