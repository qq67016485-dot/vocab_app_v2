# Transient runtime artifacts (LLM logs, scratch output, dev server logs)
temp/
tmp/

# Machine-local Claude Code settings (per-developer permission state)
.claude/settings.local.json

# Python
__pycache__/
*.pyc
.pytest_cache/
venv/
.env

# Node / frontend build
node_modules/
dist/

# Generated media (AI-produced images + LLM output logs — regenerable, large).
# Keep the directory structure so Django has somewhere to write on a fresh clone.
backend/media/
!backend/media/
backend/media/*
!backend/media/generated_images/
!backend/media/graphic_novels/
backend/media/generated_images/*
backend/media/graphic_novels/*
!backend/media/**/.gitkeep
